# ── App Config ─────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0

# ── Registration-Only Mode ─────────────────────────────────────────
# Set to 1 to restrict all routes except /register, /verify-otp, /login
# Set to 0 to allow full access to all routes
REGISTRATION_ONLY=1

# ── Admin Credentials ──────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongAdminPassword@123

# ── MongoDB Atlas ──────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/alumni_db?retryWrites=true&w=majority

# ── Gmail SMTP ─────────────────────────────────────────────────────
MAIL_USERNAME=your-gmail@gmail.com
MAIL_DEFAULT_SENDER=your-gmail@gmail.com
MAIL_PASSWORD=your-gmail-app-password-16-chars
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
